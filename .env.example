# Autonomous AI Trading Agent - Environment Variables
# Copy to .env and fill in your values

# Exchange API Keys (Binance example)
# Get keys from your exchange with read + spot trade permissions
BINANCE_API_KEY=
BINANCE_SECRET=

# For other exchanges, use: EXCHANGE_API_KEY, EXCHANGE_SECRET
# Examples: BYBIT_API_KEY, OKX_API_KEY, KRAKEN_API_KEY, KUCOIN_API_KEY, COINBASE_API_KEY

# News API (required for sentiment - pick one)
# CryptoPanic: https://cryptopanic.com/developers/api/ (free tier)
CRYPTOPANIC_API_KEY=

# Finnhub: https://finnhub.io/ (free tier, optional)
# FINNHUB_API_KEY=

# Ollama (default: http://localhost:11434)
# OLLAMA_HOST=http://localhost:11434
